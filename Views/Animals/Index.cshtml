@model IEnumerable<AdoptABuddy.Models.Animal>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<div class="row mt-4">
    
    @foreach (var item in Model)
    {
        
        <div class="col-lg-4 col-md-6 mb-4">
            
            <div class="card animal-card h-100">
                
                <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 250px; object-fit: cover;">
                <div class="card-body text-center">
                    <h4 class="card-title fw-bold">@item.Name</h4>
                    
                    <span class="badge bg-info text-dark mb-2">@item.Category?.Name</span>
                    <span class="badge bg-warning text-dark mb-2">@item.Age ani</span>
                    
                    <p class="card-text text-muted mt-3">@item.Description</p>
                    
                    <hr />
                    
                    <p class="card-text">
                        <small class="text-muted">🏠 @item.Shelter?.Name</small>
                    </p>
                </div>
                
                <div class="card-footer bg-white border-0 pb-4 d-flex justify-content-center gap-2">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Editeaza</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Detalii</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Sterge</a>
                </div>
                
            </div>
        </div>
    }
</div>

@model IEnumerable<AdoptABuddy.Models.Category>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <div class="row mt-4">
        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card animal-card h-100 text-center border-0 shadow-sm">
                    <div class="card-body py-5">
                        <div class="display-4 mb-3">🐾</div>
                    
                        <h4 class="card-title fw-bold text-uppercase" style="letter-spacing: 1px;">
                            @item.Name
                        </h4>
                    
                        <p class="text-muted small">Specie înregistrată în platformă</p>
                    </div>
                
                    <div class="card-footer bg-light border-0 py-3 d-flex justify-content-center gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Editează</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Șterge</a>
                    </div>
                </div>
            </div>
        }
    </div>
</table>

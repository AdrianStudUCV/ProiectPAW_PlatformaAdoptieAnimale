@model AdoptABuddy.Models.MedicalRecord

@{
    ViewData["Title"] = "Adaugă Fișă Medicală";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="text-center mb-4">
                <h1 class="fw-bold text-dark">Adaugă un Tratament 💉</h1>
                <p class="text-muted">Aici poți înregistra vaccinurile, deparazitările sau tratamentele animalelor din adăpost.</p>
            </div>

            <div class="card shadow-sm border-0 rounded-4" style="background-color: #fffaf0;">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Dropdown pentru Animal -->
                        <div class="form-group mb-4">
                            <label asp-for="AnimalId" class="control-label fw-bold text-dark mb-2">Pentru ce animal?</label>
                            <select asp-for="AnimalId" class="form-select rounded-pill px-3 py-2 border-warning" asp-items="ViewBag.AnimalId">
                                <option value="">-- Alege Animalul --</option>
                            </select>
                            <span asp-validation-for="AnimalId" class="text-danger small ms-2"></span>
                        </div>

                        <!-- Nume Tratament -->
                        <div class="form-group mb-4">
                            <label asp-for="TreatmentName" class="control-label fw-bold text-dark mb-2">Nume Tratament / Vaccin</label>
                            <input asp-for="TreatmentName" class="form-control rounded-pill px-3 py-2 border-warning" placeholder="Ex: Vaccin Antirabic, Deparazitare..." />
                            <span asp-validation-for="TreatmentName" class="text-danger small ms-2"></span>
                        </div>

                        <!-- Data Administrarii -->
                        <div class="form-group mb-5">
                            <label asp-for="DateAdministered" class="control-label fw-bold text-dark mb-2">Data Administrării</label>
                            <input asp-for="DateAdministered" type="date" class="form-control rounded-pill px-3 py-2 border-warning" />
                            <span asp-validation-for="DateAdministered" class="text-danger small ms-2"></span>
                        </div>

                        <!-- Butoane -->
                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-warning btn-lg rounded-pill fw-bold shadow-sm text-dark">Salvează Înregistrarea</button>
                            <a asp-controller="Animals" asp-action="Index" class="btn btn-outline-secondary rounded-pill fw-bold">Înapoi la Galeria cu Animale</a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Validarile pe partea de client -->
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
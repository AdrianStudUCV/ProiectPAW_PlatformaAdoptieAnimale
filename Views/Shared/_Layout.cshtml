@using Microsoft.AspNetCore.Identity
@inject UserManager<modelMVC.Models.ApplicationUser> UserManager
@inject SignInManager<modelMVC.Models.ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - modelMVC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/modelMVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">🐾 Adopt-a-Buddy</a>
        
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
        
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link active" asp-controller="Home" asp-action="Index">Acasă</a>
                        </li>
                
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Animals" asp-action="Index">Găsește un prieten</a>
                        </li>
                
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="CumAdopt">Cum Adopt?</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Povesti">Povești Fericite</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="Home" asp-action="DespreNoi">Despre Noi</a>
                        </li>
                    </ul>
            
                    <ul class="navbar-nav">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var user = await UserManager.GetUserAsync(User);
                            <li class="nav-item d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(user?.ProfilePictureUrl))
                                {
                                    <img src="@user.ProfilePictureUrl" alt="Profile" class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover;" />
                                }
                                <span class="nav-link text-dark fw-bold">Salut, @user.UserName!</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    <button type="submit" class="btn btn-outline-danger ms-2 rounded-pill">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link text-dark fw-bold" asp-controller="Auth" asp-action="Login">Login</a></li>
                            <li class="nav-item"><a class="btn btn-warning rounded-pill fw-bold ms-2" asp-controller="Auth" asp-action="Register">Register</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            © 2026 Adopt-a-Buddy. Salvăm vieți împreună! 🐾 <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

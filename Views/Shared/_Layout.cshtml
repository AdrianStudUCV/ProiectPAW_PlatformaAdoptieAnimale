@using Microsoft.AspNetCore.Identity
@inject UserManager<modelMVC.Models.ApplicationUser> UserManager
@inject SignInManager<modelMVC.Models.ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - modelMVC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/modelMVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">🐾 Adopt-a-Buddy</a>
        
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
        
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link active" asp-controller="Home" asp-action="Index">Acasă</a>
                        </li>
                
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Animals" asp-action="Index">Găsește un prieten</a>
                        </li>
                
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="CumAdopt">Cum Adopt?</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Povesti">Povești Fericite</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="Home" asp-action="DespreNoi">Despre Noi</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-controller="Auth" asp-action="ManageUsers">🔑Admini</a>
                            </li>
                        }
                    </ul>
            
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            // Extragem datele complete ale utilizatorului curent din baza de date
                            var currentUser = await UserManager.GetUserAsync(User);
        
                            <li class="nav-item d-flex align-items-center me-3">
                                <a asp-controller="Auth" asp-action="Profile" class="d-flex align-items-center text-decoration-none btn btn-light rounded-pill p-1 pe-3 shadow-sm transition-all" style="background-color: #fffaf0;">
                                    <img src="@(string.IsNullOrEmpty(currentUser?.ProfilePictureUrl) ? "/images/profiles/default-avatar.png" : currentUser.ProfilePictureUrl)"
                                         alt="Avatar"
                                         class="rounded-circle border border-2 border-warning me-2"
                                         style="width: 38px; height: 38px; object-fit: cover;" />
                
                                    <span class="fw-bold text-dark fs-6">Salut, @(currentUser?.FullName ?? "Utilizator")!</span>
                                </a>
                            </li>
        
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill fw-bold px-3">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link text-dark fw-bold" asp-controller="Auth" asp-action="Login">Autentificare</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-warning text-dark fw-bold rounded-pill px-3 shadow-sm" asp-controller="Auth" asp-action="Register">Înregistrare</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            © 2026 Adopt-a-Buddy. Salvăm vieți împreună! 🐾 <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@{
    ViewData["Title"] = "Gestiune Utilizatori";
}

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold text-dark">Gestiune Roluri Utilizatori 👑</h1>
        <p class="text-muted fs-5">Această pagină este vizibilă DOAR pentru Administratori. De aici poți acorda drepturi de Admin altor conturi.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 text-center shadow-sm" role="alert">
            <strong>Succes!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4" style="background-color: #fffaf0;">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="ManageUsers" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <div class="form-group mb-4">
                            <label class="control-label fw-bold text-dark mb-2">Email-ul utilizatorului pe care vrei să îl faci Admin:</label>
                            <input name="email" type="email" class="form-control rounded-pill px-3 py-2 border-warning" placeholder="Ex: colegulmeu@email.com" required />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-warning btn-lg rounded-pill fw-bold text-dark shadow-sm">
                                Acordă Drepturi de Admin 🔑
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
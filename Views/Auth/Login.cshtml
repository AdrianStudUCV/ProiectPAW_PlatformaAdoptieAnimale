@model modelMVC.Models.LoginViewModel

@{
    ViewData["Title"] = "Autentificare";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            
            <div class="text-center mb-4">
                <h1 class="fw-bold text-dark">Bine ai revenit! 👋</h1>
                <p class="text-muted font-monospace small">Adopt-a-Buddy Platform Security</p>
            </div>

            <div class="card shadow-sm border-0 rounded-4" style="background-color: #fffaf0;">
                <div class="card-body p-4 p-md-5">
                    
                    <form asp-action="Login" method="post">
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-bold"></div>

                        <div class="form-group mb-4">
                            <label asp-for="Email" class="control-label fw-bold text-dark mb-2">Adresa de Email</label>
                            <input asp-for="Email" class="form-control rounded-pill px-3 py-2 border-warning" placeholder="nume@domeniu.com" />
                            <span asp-validation-for="Email" class="text-danger small ms-2"></span>
                        </div>

                        <div class="form-group mb-5">
                            <label asp-for="Password" class="control-label fw-bold text-dark mb-2">Parolă</label>
                            <input asp-for="Password" class="form-control rounded-pill px-3 py-2 border-warning" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small ms-2"></span>
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-warning btn-lg rounded-pill fw-bold text-dark shadow-sm py-2">
                                Intră în Cont 🔓
                            </button>
                            <div class="text-center mt-2">
                                <span class="text-muted">Nu ai un cont încă?</span>
                                <a asp-action="Register" class="text-decoration-none fw-bold text-dark ms-1 opacity-75">Creează unul acum</a>
                            </div>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
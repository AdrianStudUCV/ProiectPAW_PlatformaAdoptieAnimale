@page
@model modelMVC.Views.Home.adoptieModel
@{
}
<body>

   
    <main class="container mt-5 min-vh-100">
        
        <h2 class="fw-bold mb-4">Prieteni disponibili pentru adopție</h2>

        <div class="row">
            <div class="col-lg-3 mb-4">
                <div class="filter-sidebar">
                    <h5 class="fw-bold mb-3">Filtrează</h5>
                    
                    <h6 class="fw-bold mt-3">Specie</h6>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="checkCaine" checked>
                        <label class="form-check-label" for="checkCaine">Câini</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="checkPisica" checked>
                        <label class="form-check-label" for="checkPisica">Pisici</label>
                    </div>

                    <h6 class="fw-bold mt-4">Talie</h6>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="talieMica">
                        <label class="form-check-label" for="talieMica">Mică</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="talieMedie">
                        <label class="form-check-label" for="talieMedie">Medie</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="talieMare">
                        <label class="form-check-label" for="talieMare">Mare</label>
                    </div>

                    <h6 class="fw-bold mt-4">Vârstă</h6>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="varstaPui">
                        <label class="form-check-label" for="varstaPui">Pui (< 1 an)</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="varstaAdult">
                        <label class="form-check-label" for="varstaAdult">Adult (1 - 7 ani)</label>
                    </div>
                    
                    <button class="btn btn-dark w-100 mt-4 rounded-pill">Aplică Filtre</button>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="row g-4">
                    
                    <div class="col-md-6 col-xl-4">
                        <div class="card animal-card">
                            <span class="badge badge-custom text-white">Nou sosit ✨</span>
                            <img src="imagini/poza1.jpg" class="card-img-top" alt="Max">
                            <div class="card-body">
                                <h5 class="card-title fw-bold">Max</h5>
                                <p class="card-text text-muted mb-2">Câine • Talie Medie</p>
                                <p class="small">Max este un cățel super energic care adoră să prindă mingea.</p>
                                <a href="profil-animal.html" class="btn btn-outline-dark w-100 rounded-pill mt-2">Vezi Profilul</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <div class="card animal-card">
                            <img src="imagini/poza8.jpg" class="card-img-top" alt="Luna">
                            <div class="card-body">
                                <h5 class="card-title fw-bold">Luna</h5>
                                <p class="card-text text-muted mb-2">Pisică • Pui</p>
                                <p class="small">Luna toarce non-stop și caută un loc cald unde să doarmă.</p>
                                <a href="profil-animal.html" class="btn btn-outline-dark w-100 rounded-pill mt-2">Vezi Profilul</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <div class="card animal-card">
                            <img src="imagini/poza3.jpg" class="card-img-top" alt="Rex">
                            <div class="card-body">
                                <h5 class="card-title fw-bold">Rex</h5>
                                <p class="card-text text-muted mb-2">Câine • Talie Mare</p>
                                <p class="small">Rex este un protector desăvârșit, blând cu copiii.</p>
                                <a href="profil-animal.html" class="btn btn-outline-dark w-100 rounded-pill mt-2">Vezi Profilul</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <div class="card animal-card">
                            <span class="badge bg-warning text-dark badge-custom" style="right: auto; left: 10px;">Urgent 🚨</span>
                            <img src="imagini/poza4.jpg" class="card-img-top" alt="Bella">
                            <div class="card-body">
                                <h5 class="card-title fw-bold">Bella</h5>
                                <p class="card-text text-muted mb-2">Câine • Talie Mică</p>
                                <p class="small">Bella a fost salvată recent și are nevoie de iubire.</p>
                                <a href="profil-animal.html" class="btn btn-outline-dark w-100 rounded-pill mt-2">Vezi Profilul</a>
                            </div>
                        </div>
                    </div>

                </div>
                
                <nav class="mt-5">
                    <ul class="pagination justify-content-center">
                        <li class="page-item disabled"><a class="page-link" href="#">Înapoi</a></li>
                        <li class="page-item active"><a class="page-link bg-warning border-warning text-dark" href="#">1</a></li>
                        <li class="page-item"><a class="page-link text-dark" href="#">2</a></li>
                        <li class="page-item"><a class="page-link text-dark" href="#">Următoarea</a></li>
                    </ul>
                </nav>

            </div>
        </div>
    </main>

   

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
@model IEnumerable<modelMVC.Models.AdoptionStory>

@{
    ViewData["Title"] = "Povești Fericite";
}

<div class="container mt-5 mb-5 text-center">
    <h1 class="fw-bold mb-4">Povești care ne topesc inima ❤️</h1>
    <p class="text-muted mb-5">Acestea sunt doar câteva dintre sufletele care și-au găsit o familie iubitoare prin Adopt-a-Buddy.</p>

    @if (!Model.Any())
    {
        <!-- Afisam asta doar daca nu am introdus inca nicio poveste in baza de date -->
        <div class="alert alert-info rounded-4 py-4">
            <p class="mb-0">Momentan nu avem nicio poveste înregistrată în sistem. Fii tu primul care scrie una!</p>
        </div>
    }
    else
    {
        <div class="row justify-content-center text-start">
            @foreach (var story in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm border-0 rounded-4 h-100 p-3">
                        @if (!string.IsNullOrEmpty(story.ImageUrl))
                        {
                            <img src="@story.ImageUrl" class="card-img-top rounded-3 mb-3" alt="@story.AnimalName" style="height: 250px; object-fit: cover;">
                        }
                        
                        <div class="card-body p-0">
                            <span class="badge bg-success rounded-pill mb-2 px-3 py-2">
                                Adopție: @story.AdoptionDate.ToString("MMMM yyyy")
                            </span>
                            <h4 class="card-title fw-bold">@story.AnimalName și @story.AdopterName</h4>
                            
                            <!-- Aceasta este bara galbena verticala din design-ul tau -->
                            <blockquote class="blockquote mt-3 ps-3" style="border-left: 4px solid #ffc107;">
                                <p class="small fst-italic text-muted">
                                    "@story.StoryText"
                                </p>
                            </blockquote>
                            
                            <p class="text-end small text-muted mb-0">— Familia @story.AdopterName</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Butonul dinamic functional cerut in screenshot -->
    <div class="mt-5">
        <h5 class="fw-bold mb-3">Ești gata să scrii propria poveste?</h5>
        <a asp-controller="Animals" asp-action="Index" class="btn btn-warning btn-lg fw-bold px-5 py-3 rounded-pill shadow-sm">
            Găsește-ți Prietenul Acum
        </a>
    </div>
</div>
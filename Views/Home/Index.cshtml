@model IEnumerable<AdoptABuddy.Models.Animal>
@{
    ViewData["Title"] = "Home Page";
}

<body>

    <main class="container min-vh-100">
        
        <div class="hero-section text-center mb-5 shadow-sm">
            <h1 class="display-4 fw-bold mb-3">Găsește-ți cel mai bun prieten! 🐶🐱</h1>
            <p class="lead mb-4">Sute de animale din Craiova așteaptă o familie iubitoare. Oferă-le o șansă la o viață fericită!</p>
            <a asp-controller="Animals" asp-action="Index" class="btn btn-warning btn-lg fw-bold px-4 py-2 rounded-pill shadow-sm">Vezi Animalele Disponibile</a>
        </div>

        <h2 class="fw-bold text-center mb-4">Prieteni care au nevoie de tine urgent</h2>
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card animal-card h-100">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover;">
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">@item.Name</h5>
                            <p class="card-text text-muted">@item.Category?.Name • @item.Age ani</p>
                            <a asp-controller="Animals" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-warning">Vezi Profilul</a>
                        </div>
                    </div>
                </div>
            }
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
@model modelMVC.Models.ContactMessage

@{
    ViewData["Title"] = "Contactează-ne";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="text-center mb-4">
                <h1 class="fw-bold">Spune-ne un "Ham" sau un "Miau"! 🐾</h1>
                <p class="text-muted">Ai o întrebare despre adopție sau vrei să ne cunoști? Scrie-ne mai jos.</p>
            </div>

            <!-- Zona pentru Mesajul de Succes -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4" role="alert">
                    <strong>Super!</strong> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Cardul cu Formularul -->
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Contact" method="post">
                        <!-- Nume -->
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold">Cum te numești?</label>
                            <input asp-for="Name" class="form-control rounded-pill px-3 py-2" placeholder="Ex: Popescu Ion" />
                            <span asp-validation-for="Name" class="text-danger small ms-2"></span>
                        </div>

                        <!-- Email -->
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-bold">Adresa ta de email</label>
                            <input asp-for="Email" class="form-control rounded-pill px-3 py-2" placeholder="nume@domeniu.com" />
                            <span asp-validation-for="Email" class="text-danger small ms-2"></span>
                        </div>

                        <!-- Mesaj -->
                        <div class="mb-4">
                            <label asp-for="Message" class="form-label fw-bold">Mesajul tău</label>
                            <textarea asp-for="Message" class="form-control rounded-4 px-3 py-2" rows="5" placeholder="Scrie aici mesajul tău..."></textarea>
                            <span asp-validation-for="Message" class="text-danger small ms-2"></span>
                        </div>

                        <!-- Buton Submit -->
                        <div class="d-grid mt-5">
                            <button type="submit" class="btn btn-warning btn-lg rounded-pill fw-bold">Trimite Mesajul 🚀</button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Script-urile necesare pentru ca validarile sa functioneze in timp real pe partea de client -->
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
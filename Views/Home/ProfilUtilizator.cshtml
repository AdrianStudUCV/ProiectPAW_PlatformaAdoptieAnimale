@page
@model modelMVC.Views.Home.ProfilUtilizatorModel
@{
}
<body>

   

    <main class="container mt-5 min-vh-100">
        
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="profile-card">
                    <div class="user-avatar shadow-sm">A</div>
                    <h3 class="fw-bold mb-1">Alex Preda</h3>
                    <p class="text-muted mb-4">Membru din Martie 2026</p>
                    
                    <div class="text-start mb-4">
                        <p class="mb-2"><strong>Email:</strong><br> alex@email.com</p>
                        <p class="mb-2"><strong>Telefon:</strong><br> 0722 123 456</p>
                        <p class="mb-0"><strong>Adresă:</strong><br> Craiova, Dolj, România</p>
                    </div>
                    
                    <button class="btn btn-outline-dark w-100 rounded-pill mb-2">Editează Profilul</button>
                    <a href="#" class="btn btn-light w-100 rounded-pill text-danger fw-bold">Deconectare</a>
                </div>
            </div>

            <div class="col-lg-8">
                
                <h3 class="fw-bold mb-4">Panoul Meu</h3>

                <div class="dashboard-card border-start border-warning border-5">
                    <h5 class="fw-bold mb-3">🐶 Cereri de adopție active</h5>
                    
                    <div class="animal-row-item shadow-sm">
                        <img src="imagini/poza1.jpg" class="mini-animal-img me-3" alt="Max">
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-1">Câinele Max</h6>
                            <p class="text-muted small mb-0">Cerere trimisă pe: 5 Martie 2026</p>
                        </div>
                        <div class="ms-2">
                            <span class="status-badge bg-warning text-dark fw-bold">⏳ În așteptare</span>
                        </div>
                    </div>
                </div>

                <div class="dashboard-card border-start border-info border-5">
                    <h5 class="fw-bold mb-3">❤️ Animale salvate la favorite</h5>
                    
                    <div class="animal-row-item shadow-sm">
                        <img src="imagini/poza8.jpg" class="mini-animal-img me-3" alt="Luna">
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-1">Pisica Luna</h6>
                            <p class="text-muted small mb-0">Adăpostul "Suflete Neclintite"</p>
                        </div>
                        <div class="ms-2">
                            <a href="profil-animal.html" class="btn btn-outline-dark btn-vezi-mic">Vezi din nou</a>
                        </div>
                    </div>

                    <div class="d-flex align-items-center bg-light p-3 rounded-4">
                        <img src="imagini/poza4.jpg" class="mini-animal-img me-3" alt="Bella">
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-1">Cățelușa Bella</h6>
                            <p class="text-muted small mb-0">Urgent - Caută foster</p>
                        </div>
                        <div class="text-end">
                            <a href="profil-animal.html" class="btn btn-sm btn-outline-dark rounded-pill px-3">Vezi din nou</a>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </main>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
@model IEnumerable<AdoptABuddy.Models.Shelter>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <div class="row mt-4">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card animal-card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-warning rounded-circle p-3 me-3">
                                🏠
                            </div>
                            <h4 class="card-title fw-bold mb-0">@item.Name</h4>
                        </div>
                    
                        <hr class="text-muted opacity-25" />
                    
                        <div class="ps-2">
                            <p class="card-text mb-2">
                                <strong>📍 Adresă:</strong> <br />
                                <span class="text-muted">@item.Address</span>
                            </p>
                        
                            <p class="card-text">
                                <strong>📞 Contact:</strong> <br />
                                <span class="text-muted">@item.PhoneNumber</span>
                            </p>
                        </div>
                    </div>
                
                    <div class="card-footer bg-white border-0 pb-4 d-flex justify-content-center gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning px-3">Editează</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info px-3">Detalii</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger px-3">Șterge</a>
                    </div>
                </div>
            </div>
        }
    </div>
</table>
